# Maintainer: Gigas002 <gigas002@pm.me>

pkgname=speaches-git
_pkgname=speaches
pkgver=0
pkgrel=1
pkgdesc="OpenAI API-compatible speech server (STT/TTS/realtime) — git"
arch=('x86_64' 'aarch64')
url="https://github.com/speaches-ai/$_pkgname"
license=('MIT')
depends=(
  'python312'
  'ffmpeg'
  'libsndfile'
  'portaudio'
  'onnxruntime-opt-rocm'
)
makedepends=('git' 'uv')
optdepends=('cuda: GPU inference (see https://speaches.ai/installation/ and upstream Docker images)')
provides=("$_pkgname")
conflicts=("$_pkgname")
options=('!strip')
source=("git+$url.git")
b2sums=('SKIP')

pkgver() {
  cd "$srcdir/$_pkgname"
  printf "r%s.%s" "$(git rev-list --count HEAD)" "$(git rev-parse --short=7 HEAD)"
}

package() {
  cd "$srcdir/$_pkgname"

  export UV_PYTHON=python3.12
  export PYTHONNOUSERSITE=1

  uv pip install \
    --python=python3.12 \
    --prefix="$pkgdir/usr" \
    --no-compile-bytecode \
    . \
    ./packages/speaches-cli

  install -Dm755 /dev/stdin "$pkgdir/usr/bin/speaches-serve" <<'EOF'
#!/bin/sh
exec python3.12 -m uvicorn --factory --host 0.0.0.0 speaches.main:create_app "$@"
EOF

  install -Dm644 LICENSE -t "$pkgdir/usr/share/licenses/$pkgname/"
  install -Dm644 README.md -t "$pkgdir/usr/share/doc/$_pkgname/"
}
