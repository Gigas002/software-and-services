# Prefer using rocm-gfx120x-bin package for all rocm deps at once
pkgname=libggml-hip-git
pkgver=v0.11.1.r25.g57ea0bc
pkgrel=1
pkgdesc="ggml (git) — ROCm HIP + CPU (Zen-class SIMD flags)"
arch=('x86_64')
url="https://github.com/ggml-org/ggml"
license=('MIT')
depends=('gcc-libs' 'hip-runtime-amd' 'rocblas' 'hipblas')
makedepends=('cmake' 'git' 'ninja')
provides=('libggml-git' 'libggml')
conflicts=('libggml' 'libggml-git' 'libggml-zen5-git' 'libggml-vulkan-git')
source=('ggml::git+https://github.com/ggml-org/ggml.git'
        'no-wmma.patch')
sha256sums=('SKIP'
            'SKIP')

pkgver() {
  cd "$srcdir/ggml"
  git describe --long --tags --abbrev=7 2>/dev/null | sed 's/\([^-]*-g\)/r\1/;s/-/./g' \
    || printf 'r%s.%s' "$(git rev-list --count HEAD)" "$(git rev-parse --short=7 HEAD)"
}

prepare() {
  cd "$srcdir/ggml"
  # patch -Np1 < "$startdir/no-wmma.patch"
}

build() {
    # -DCMAKE_HIP_FLAGS="-DGGML_HIP_NO_WMMA=1" \
  cmake -B build -G Ninja -S "$srcdir/ggml" \
    -DCMAKE_BUILD_TYPE=Release \
    -DCMAKE_INSTALL_PREFIX=/usr \
    -DGGML_HIP=ON \
    -DGPU_TARGETS="gfx1201" \
    -DGGML_OPENMP=ON \
    -DGGML_NATIVE=ON \
    -DGGML_LTO=ON \
    -DGGML_FMA=ON \
    -DGGML_F16C=ON \
    -DGGML_AVX512=ON \
    -DGGML_AVX512_VBMI=ON \
    -DGGML_AVX512_VNNI=ON \
    -DGGML_AVX512_BF16=ON \
    -DGGML_AVX_VNNI=ON \
    -DGGML_BUILD_TESTS=OFF \
    -DGGML_BUILD_EXAMPLES=OFF \
    -DGGML_ALL_WARNINGS=OFF \
    -DGGML_ALL_WARNINGS_3RD_PARTY=OFF \
    -DBUILD_SHARED_LIBS=ON \
    -Wno-dev
  cmake --build build
}

package() {
  DESTDIR="$pkgdir" cmake --install build
  install -Dm644 "$srcdir/ggml/LICENSE" -t "$pkgdir/usr/share/licenses/$pkgname/"
}
