# Maintainer: gigas002 <gigas002@pm.me>

_pkgname="wayshot"
pkgname="${_pkgname}-master-git"
pkgver=r401.d7fb0a4
pkgrel=1
pkgdesc="Screenshoting tool"
arch=("x86_64")
url="https://github.com/Gigas002/wayshot"
license=('GPL3')
depends=(pango libjxl)
makedepends=(git cargo)
provides=(${_pkgname})
conflicts=(${_pkgname})
source=("${_pkgname}::git+$url.git#branch=test/vk-ref")
sha256sums=('SKIP')

#prepare() {
#  cd "${srcdir}/${_pkgname}"
#  git checkout 9165029685297fb8a10f77c826cdeae740c4d842
#}

pkgver() {
  cd "${_pkgname}"
  ( set -o pipefail
    git describe --long 2>/dev/null | sed 's/\([^-]*-g\)/r\1/;s/-/./g' ||
    printf "r%s.%s" "$(git rev-list --count HEAD)" "$(git rev-parse --short HEAD)"
  )
}

build() {
  cd "${srcdir}/${_pkgname}"
  cargo build --no-default-features --features vulkan,jxl,selector --release
}

package() {
  cd "${_pkgname}"
  install -Dm0755 -t "$pkgdir/usr/bin/" "target/release/${_pkgname}"
}
